CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_MULTI_PROFILE=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-ss-01=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02=n
#CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02="luci-app-athena-led luci-i18n-athena-led-zh-cn"

CONFIG_ATH11K_MEM_PROFILE_512M=y
CONFIG_NSS_FIRMWARE_VERSION_12_5=y
CONFIG_PACKAGE_luci-app-athena-led=n
CONFIG_PACKAGE_luci-i18n-athena-led-zh-cn=n

#nikki momo等代理依赖内核kmod-nft-socket kmod-nft-core kmod-nfnetlink-queue
CONFIG_PACKAGE_kmod-dummy=y
CONFIG_PACKAGE_kmod-inet-diag=y
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_kmod-netlink-diag=y
CONFIG_PACKAGE_libncurses=y
CONFIG_PACKAGE_libncursesw6=y
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-nft-socket=y
CONFIG_PACKAGE_kmod-tls=y
CONFIG_PACKAGE_kmod-nft-fullcone=y
CONFIG_PACKAGE_kmod-nft-queue=y
CONFIG_PACKAGE_kmod-nfnetlink-queue=y
CONFIG_PACKAGE_uci-firewall=y

# iptables 基础nat/physdev/extra/ipvs/veth 内核模块
CONFIG_PACKAGE_kmod-ipt-extra=y
CONFIG_PACKAGE_kmod-ipt-nat=y
CONFIG_PACKAGE_kmod-ipt-nat6=y
CONFIG_PACKAGE_kmod-ipt-physdev=y
CONFIG_PACKAGE_kmod-nf-ipvs=y
CONFIG_PACKAGE_kmod-veth=y

#多线多播内核
CONFIG_PACKAGE_kmod-ipt-ipset=y
CONFIG_PACKAGE_kmod-ipt-conntrack-extra=y
CONFIG_PACKAGE_kmod-ipt-ipopt=y
CONFIG_PACKAGE_kmod-nft-compat=y
CONFIG_PACKAGE_kmod-ip6tables=y

# NSS图形界面
CONFIG_PACKAGE_luci-app-nss=y
CONFIG_PACKAGE_luci-i18n-nss-zh-cn=y

CONFIG_PACKAGE_nginx-full=y
CONFIG_PACKAGE_logrotate=y
CONFIG_PACKAGE_luci-app-openlist2=n

### Aria2配置项 ###

CONFIG_PACKAGE_ariang=y
CONFIG_PACKAGE_luci-app-aria2=y

CONFIG_ARIA2_OPENSSL=y
# CONFIG_ARIA2_GNUTLS is not set
# CONFIG_ARIA2_NOSSL is not set
# CONFIG_ARIA2_LIBXML2 is not set
CONFIG_ARIA2_EXPAT=y
# CONFIG_ARIA2_NOXML is not set
CONFIG_ARIA2_BITTORRENT=y
CONFIG_ARIA2_METALINK=y
CONFIG_ARIA2_SFTP=y
CONFIG_ARIA2_ASYNC_DNS=y
# CONFIG_ARIA2_COOKIE is not set
CONFIG_ARIA2_WEBSOCKET=y

# --- Nikki 相关 ---
CONFIG_PACKAGE_nikki=y
CONFIG_PACKAGE_luci-app-nikki=y
CONFIG_PACKAGE_luci-i18n-nikki-zh-cn=y
CONFIG_PACKAGE_mihomo=y
# --- Momo 相关 ---
CONFIG_PACKAGE_momo=y
CONFIG_PACKAGE_luci-app-momo=y
CONFIG_PACKAGE_luci-i18n-momo-zh-cn=y

# --- DDnsGo 相关 ---
CONFIG_PACKAGE_ddns-go=y
CONFIG_PACKAGE_luci-i18n-ddns-go-zh-cn=y
CONFIG_PACKAGE_luci-app-ddns-go=y
